# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/newsletter

# --- Auth ---
# 32+ random characters. Generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-long-random-string-min-32-chars

# --- Email Provider ---
# Set provider to one of: smtp | resend | mailgun | sendgrid | postmark | ses
MAIL_PROVIDER=smtp
MAIL_FROM_NAME=Newsletter
MAIL_FROM_ADDRESS=hello@example.com
MAIL_REPLY_TO=

# SMTP (used if MAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Resend
RESEND_API_KEY=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us  # or eu

# SendGrid
SENDGRID_API_KEY=

# Postmark
POSTMARK_API_KEY=

# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Webhooks ---
# Used to sign tracking links and validate webhook payloads
TRACKING_SECRET=replace-me-tracking-secret

# --- Queue / Worker ---
# How many emails per minute to send (rate limit your provider properly)
SEND_RATE_LIMIT=120
# Concurrent send workers
SEND_CONCURRENCY=4

# --- Cron auth ---
# Required header for /api/cron/* endpoints when self-hosting
CRON_SECRET=replace-me-cron-secret
